# Copy this to .env and fill in values for local development.
# Never commit .env to source control.

# ── AWS (LocalStack uses dummy values locally) ──────────────────────────────
AWS_ACCESS_KEY_ID=temp
AWS_SECRET_ACCESS_KEY=temp
AWS_DEFAULT_REGION=us-east-1

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=info

# ── DynamoDB table names ─────────────────────────────────────────────────────
GOALS_TABLE=Labe-Local-Goals

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_FAST_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5.1
